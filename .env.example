# ai-scout — environment template. Copy to .env and fill. Never commit .env.

# ---- FreshRSS (system of record) ----
FRESHRSS_PORT=8080
# Timezone for digests/scheduling
TZ=Asia/Kolkata
# Admin account created on first run
FRESHRSS_ADMIN_USER=admin
FRESHRSS_ADMIN_PASSWORD=change-me-long-random
# Cron schedule for FreshRSS feed refresh (inside container)
FRESHRSS_CRON_MIN=*/20

# ---- RSSHub (ingest adapters) ----
RSSHUB_PORT=1200
# Cache TTL seconds; keep modest to be polite to sources
RSSHUB_CACHE_EXPIRE=3600
# Optional access key if you expose RSSHub beyond localhost (leave blank for local)
RSSHUB_ACCESS_KEY=
