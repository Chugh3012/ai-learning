# ai-scout — environment template. Copy to .env and fill. Never commit .env.

# ---- FreshRSS (system of record) ----
FRESHRSS_PORT=8080
# Timezone for digests/scheduling
TZ=Asia/Kolkata
# Admin account created on first run
FRESHRSS_ADMIN_USER=admin
FRESHRSS_ADMIN_PASSWORD=change-me-long-random
# Cron schedule for FreshRSS feed refresh (inside container)
FRESHRSS_CRON_MIN=*/20

# ---- RSSHub (ingest adapters) ----
RSSHUB_PORT=1200
# Cache TTL seconds; keep modest to be polite to sources
RSSHUB_CACHE_EXPIRE=3600
# Optional access key if you expose RSSHub beyond localhost (leave blank for local)
RSSHUB_ACCESS_KEY=

# ---- P3 owned knowledge base (Azure Blob, Entra/RBAC — no keys) ----
# Set for local `python tools/kb_sync.py` runs. In GitHub Actions these come from repo Variables.
STORAGE_ACCOUNT=
BLOB_CONTAINER=knowledge

# ---- P4 relevance ranking (Microsoft Foundry project, Entra — no keys) ----
# Leave FOUNDRY_PROJECT_ENDPOINT blank to skip ranking (digest falls back to recency).
# Form: https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_NAME=nano
# Embedding deployment for two-tower personalization (embeds items + each user's interest;
# per-user match = a cheap dot product). Blank = skip embeddings (delivery falls back to the
# shared relevance + that user's feedback only).
FOUNDRY_EMBED_NAME=embed

# ---- P6 email delivery (Azure Communication Services, Entra — no keys) ----
# Leave ACS_ENDPOINT blank to skip email. Sender is the Azure-managed domain address.
ACS_ENDPOINT=
EMAIL_SENDER=
EMAIL_TO=

# ---- P7 feedback loop (Azure Function + Tables, Entra — no keys) ----
# FEEDBACK_URL: the deployed Function route that records 👍/👎/save/click from email links,
#   e.g. https://fn-ai-scout-fb.azurewebsites.net/api/f  (blank = email sends plain links).
# FEEDBACK_STORAGE: the function storage account holding the feedbacktokens/feedbackevents
#   tables. Used by kb_sync --feedback to ingest gestures into the KB and tune ranking.
FEEDBACK_URL=
FEEDBACK_STORAGE=
